<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calcScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#f9fafb">

    <LinearLayout
        android:id="@+id/calcRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/calcTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/calculator_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/resultLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/result"
            android:textColor="#64748b"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:paddingTop="8dp"
            android:paddingBottom="16dp" />

        <EditText
            android:id="@+id/numberAInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/number_a"
            android:inputType="numberDecimal|numberSigned"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/numberBInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/number_b"
            android:inputType="numberDecimal|numberSigned"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/opRow1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/addButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/add"
                android:textAllCaps="false"
                android:backgroundTint="#3b82f6"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/subtractButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/subtract"
                android:textAllCaps="false"
                android:backgroundTint="#64748b"
                android:textColor="@android:color/white"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/opRow2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/multiplyButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/multiply"
                android:textAllCaps="false"
                android:backgroundTint="#06b6d4"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/divideButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/divide"
                android:textAllCaps="false"
                android:backgroundTint="#111827"
                android:textColor="@android:color/white"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/calcErrorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#EF4444"
            android:layout_marginTop="14dp"
            android:visibility="gone"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
